PROXY_HOST=127.0.0.1
PROXY_PORT=8789
UPSTREAM_PROVIDER_ID=vivgrid
UPSTREAM_FALLBACK_PROVIDER_IDS=ollama-cloud
# Leave UPSTREAM_BASE_URL unset to derive it from UPSTREAM_PROVIDER_ID / UPSTREAM_PROVIDER_BASE_URLS.
# UPSTREAM_BASE_URL=
UPSTREAM_PROVIDER_BASE_URLS=vivgrid=https://api.vivgrid.com,ollama-cloud=https://ollama.com,ob1=https://dashboard.openblocklabs.com/api,openrouter=https://openrouter.ai/api/v1,requesty=https://router.requesty.ai/v1
OPENAI_PROVIDER_ID=openai
OPENAI_BASE_URL=https://chatgpt.com/backend-api
# Official OpenAI Platform API base URL (used for images).
OPENAI_API_BASE_URL=https://api.openai.com

# OpenAI OAuth (browser/device flow) configuration.
# Defaults match Codex CLI style public client.
OPENAI_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
# Optional: only needed for confidential clients.
# OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_ISSUER=https://auth.openai.com
# For Platform API access you likely need additional scopes, e.g.
# OPENAI_OAUTH_SCOPES=openid profile email offline_access api.model.read api.responses.write api.model.images.request
OPENAI_OAUTH_SCOPES=openid profile email offline_access

# Optional: fallback paths when using ChatGPT backend image endpoints.
# OPENAI_IMAGES_GENERATIONS_PATHS=/v1/images/generations,/images/generations,/codex/images/generations
OLLAMA_BASE_URL=http://ollama:11434
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# REQUESTY_BASE_URL=https://router.requesty.ai/v1
# OPENROUTER_API_KEY=
# REQUESTY_API_TOKEN=   # alias of REQUESTY_API_KEY; set either one
# REQUESTY_API_KEY=     # alias of REQUESTY_API_TOKEN; set either one
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY=
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# ZHIPU_BASE_URL=https://api.z.ai/api/paas/v4  # alias of ZAI_BASE_URL; set either one
# ZAI_API_KEY=
# ZHIPU_API_KEY=        # alias of ZAI_API_KEY; set either one
# ZAI_PROVIDER_ID=zai   # optional override; default is zai
# ZHIPU_PROVIDER_ID=zai # alias of ZAI_PROVIDER_ID; set either one
UPSTREAM_CHAT_COMPLETIONS_PATH=/v1/chat/completions
OPENAI_CHAT_COMPLETIONS_PATH=/codex/responses/compact
UPSTREAM_MESSAGES_PATH=/v1/messages
UPSTREAM_MESSAGES_MODEL_PREFIXES=claude-
# Set empty to disable automatic interleaved-thinking beta header.
UPSTREAM_MESSAGES_INTERLEAVED_THINKING_BETA=interleaved-thinking-2025-05-14
UPSTREAM_RESPONSES_PATH=/v1/responses
OPENAI_RESPONSES_PATH=/codex/responses
UPSTREAM_IMAGES_GENERATIONS_PATH=/v1/images/generations
# Default USD cost per generated image (0 disables cost tracking).
# IMAGE_COST_USD_DEFAULT=0
# Optional per-provider overrides (lowercased provider_id=usd), comma-separated.
# IMAGE_COST_USD_BY_PROVIDER=openai=0.04,gemini=0.02
UPSTREAM_RESPONSES_MODEL_PREFIXES=gpt-
OPENAI_MODEL_PREFIXES=openai/,openai:
OLLAMA_CHAT_PATH=/api/chat
OLLAMA_MODEL_PREFIXES=ollama/,ollama:
PROXY_KEYS_FILE=./keys.json
PROXY_MODELS_FILE=./models.json
PROXY_REQUEST_LOGS_FILE=./data/request-logs.jsonl
PROXY_KEY_RELOAD_MS=5000
PROXY_KEY_COOLDOWN_MS=30000
# Batch request log journal flushes/compactions to reduce write amplification under concurrent traffic.
PROXY_REQUEST_LOGS_FLUSH_MS=1000
# Batch prompt-affinity snapshot writes so cache pinning does not serialize on disk I/O.
PROXY_PROMPT_AFFINITY_FLUSH_MS=250
UPSTREAM_REQUEST_TIMEOUT_MS=180000
PROXY_AUTH_TOKEN=change-me-open-hax-proxy-token
# Set true only for local debugging if you cannot supply a bearer token.
# PROXY_ALLOW_UNAUTHENTICATED=true

# Database Configuration (PostgreSQL for Render/cloud deployment)
# DATABASE_URL is set automatically by Render when using Blueprint
# For local development, you can use:
# DATABASE_URL=postgresql://localhost:5432/openai_proxy

# Session Secret (for OAuth cookies when using database)
SESSION_SECRET=change-me-session-secret-for-oauth

# GitHub OAuth Configuration (for user authentication)
# Create an OAuth App at https://github.com/settings/developers
# GITHUB_OAUTH_CLIENT_ID=your-github-oauth-client-id
# GITHUB_OAUTH_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_OAUTH_CALLBACK_PATH=/auth/github/callback

# Comma-separated list of allowed GitHub usernames
# GITHUB_ALLOWED_USERS=user1,user2,user3

# Optional UI semantic-search settings
# CHROMA_URL=http://127.0.0.1:8000
# CHROMA_COLLECTION=open_hax_proxy_sessions
# Chroma uses Ollama embeddings through the JS client.
# CHROMA_EMBED_MODEL=nomic-embed-text:latest

# Optional multi-host fleet dashboard.
# The current console host can usually be inferred from the request host, but you can pin it explicitly.
# HOST_DASHBOARD_SELF_ID=ussy
# HOST_DASHBOARD_TARGETS_JSON=[{"id":"ussy","label":"ussy.promethean.rest","baseUrl":"https://ussy.promethean.rest","authTokenEnv":"HOST_DASHBOARD_USSY_TOKEN"},{"id":"ussy3","label":"ussy3.promethean.rest","baseUrl":"https://ussy3.promethean.rest","authTokenEnv":"HOST_DASHBOARD_USSY3_TOKEN"}]
# HOST_DASHBOARD_USSY_TOKEN=
# HOST_DASHBOARD_USSY3_TOKEN=
# Include docker-compose.host-dashboard.override.yml if you want local Docker/runtime introspection.
# HOST_DASHBOARD_DOCKER_SOCKET_PATH=/var/run/docker.sock
# HOST_DASHBOARD_RUNTIME_ROOT=/workspace/runtime-repo
# HOST_DASHBOARD_REQUEST_TIMEOUT_MS=5000

# Optional outbound federation bridge agent.
# Set these on the designated local/enclave cluster-agent process to connect it to a public relay.
# FEDERATION_BRIDGE_RELAY_URL=wss://staging.example/api/ui/federation/bridge/ws
# FEDERATION_BRIDGE_AUTH_TOKEN=change-me-bridge-auth-token
# FEDERATION_BRIDGE_AUTH_MODE=admin_key
# FEDERATION_BRIDGE_AGENT_ID=local-cluster-agent
# FEDERATION_BRIDGE_OWNER_SUBJECT=did:plc:...
# FEDERATION_BRIDGE_LABELS=local,oauth-enclave
# FEDERATION_BRIDGE_NODE_LABELS=default
# FEDERATION_BRIDGE_DEFAULT_EXECUTION_POLICY=node_affinity
# FEDERATION_BRIDGE_ENVIRONMENT=local
# FEDERATION_BRIDGE_AGENT_VERSION=0.1.0
# FEDERATION_BRIDGE_RECONNECT_MIN_MS=500
# FEDERATION_BRIDGE_RECONNECT_MAX_MS=5000
# Existing federation identity env is reused by the bridge agent when present:
# FEDERATION_SELF_CLUSTER_ID=local-dev
# FEDERATION_SELF_GROUP_ID=group-a
# FEDERATION_SELF_NODE_ID=a1
# FEDERATION_SELF_PEER_DID=did:web:local.promethean.rest
# FEDERATION_DEFAULT_OWNER_SUBJECT=did:plc:...
