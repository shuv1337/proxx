{
  "name": "@workspace/open-hax-openai-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible chat proxy with provider account rotation.",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "pnpm run build && node --test --test-concurrency=1 dist/tests/*.test.js",
    "test:e2e": "./scripts/e2e-test.sh",
    "test:e2e:multitenancy": "./scripts/e2e-multitenancy-smoke.sh",
    "test:e2e:federation": "./scripts/e2e-federation-cluster.sh",
    "test:e2e:federation:audit": "./scripts/e2e-federation-audit.sh",
    "test:load": "node ./scripts/load-test.mjs",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts",
    "lint": "eslint .",
    "lint:errors": "eslint . --quiet"
  },
  "dependencies": {
    "@devel/ui-react": "file:../../../packages/ui/react",
    "@devel/ui-tokens": "file:../../../packages/ui/tokens",
    "@fastify/cookie": "^11.0.2",
    "@fastify/swagger": "9.5.1",
    "@fastify/swagger-ui": "5.2.3",
    "chromadb": "^3.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fastify": "^5.0.0",
    "postgres": "^3.4.8",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.1",
    "eslint-plugin-sonarjs": "^3.0.6",
    "imapflow": "^1.2.13",
    "playwright": "^1.58.2",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.4.10"
  }
}
