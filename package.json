{
  "name": "@workspace/open-hax-openai-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "OpenAI-compatible chat proxy with provider account rotation.",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/main.ts",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "test": "pnpm run build && node --test --test-concurrency=1 dist/tests/*.test.js",
    "test:e2e": "./scripts/e2e-test.sh",
    "test:e2e:multitenancy": "./scripts/e2e-multitenancy-smoke.sh",
    "test:load": "node ./scripts/load-test.mjs",
    "web:dev": "vite --config web/vite.config.ts",
    "web:build": "vite build --config web/vite.config.ts",
    "web:preview": "vite preview --config web/vite.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "chromadb": "^3.2.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fastify": "^4.27.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "imapflow": "^1.2.13",
    "playwright": "^1.58.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
