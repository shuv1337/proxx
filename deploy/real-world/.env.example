# Real-world proxx deployment env for shuv.dev host
# Copy to .env and fill/adjust as needed before syncing to the host.

NODE_ENV=production
PROXY_HOST=0.0.0.0
PROXY_PORT=3001
PORT=3001
PROXY_WEB_PORT=5174
OPENAI_OAUTH_CALLBACK_PORT=1455

# Required admin token for UI/API access. Also injected into VMs via shuvdev.
PROXY_AUTH_TOKEN=change-me-proxx-admin-token

# PostgreSQL on the same docker-compose stack
DATABASE_URL=postgresql://openai_proxy:openai_proxy@open-hax-openai-proxy-db:5432/openai_proxy
SESSION_SECRET=change-me-session-secret

# GitHub OAuth for browser login (optional but recommended for multi-user admin access)
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# GITHUB_ALLOWED_USERS=
# GITHUB_OAUTH_CALLBACK_PATH=/auth/github/callback

# Provider routing defaults. Keep these simple until provider accounts are added via the UI.
UPSTREAM_PROVIDER_ID=openai
UPSTREAM_FALLBACK_PROVIDER_IDS=ollama-cloud,requesty
DISABLED_PROVIDER_IDS=
UPSTREAM_BASE_URL=https://chatgpt.com/backend-api
UPSTREAM_PROVIDER_BASE_URLS=ollama-cloud=https://ollama.com,openai=https://chatgpt.com/backend-api,vivgrid=https://api.vivgrid.com,requesty=https://router.requesty.ai/v1,openrouter=https://openrouter.ai/api/v1,gemini=https://generativelanguage.googleapis.com/v1beta,factory=https://api.factory.ai

OPENAI_PROVIDER_ID=openai
OPENAI_BASE_URL=https://chatgpt.com/backend-api
OPENAI_API_BASE_URL=https://api.openai.com
OPENAI_IMAGES_UPSTREAM_MODE=auto
OPENAI_OAUTH_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
OPENAI_OAUTH_ISSUER=https://auth.openai.com
OPENAI_OAUTH_SCOPES=openid profile email offline_access
# OPENAI_OAUTH_CLIENT_SECRET=

UPSTREAM_CHAT_COMPLETIONS_PATH=/v1/chat/completions
UPSTREAM_MESSAGES_PATH=/v1/messages
UPSTREAM_MESSAGES_MODEL_PREFIXES=claude-
UPSTREAM_MESSAGES_INTERLEAVED_THINKING_BETA=interleaved-thinking-2025-05-14
UPSTREAM_RESPONSES_PATH=/v1/responses
UPSTREAM_RESPONSES_MODEL_PREFIXES=gpt-
OPENAI_CHAT_COMPLETIONS_PATH=/codex/responses/compact
OPENAI_RESPONSES_PATH=/codex/responses
OLLAMA_CHAT_PATH=/api/chat
OLLAMA_MODEL_PREFIXES=ollama/,ollama:
OPENAI_MODEL_PREFIXES=openai/,openai:

# Optional env-backed providers. Leave blank if you plan to add accounts through the UI.
REQUESTY_API_TOKEN=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
FACTORY_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
CHROMA_URL=http://host.docker.internal:8000
CHROMA_COLLECTION=open_hax_proxy_sessions
CHROMA_EMBED_MODEL=nomic-embed-text:latest

# Keep auth on; health remains public.
PROXY_ALLOW_UNAUTHENTICATED=false
PROXY_REQUEST_LOGS_MAX_ENTRIES=100000
PROXY_KEY_RELOAD_MS=5000
PROXY_KEY_COOLDOWN_MS=30000
UPSTREAM_REQUEST_TIMEOUT_MS=180000
UPSTREAM_STREAM_BOOTSTRAP_TIMEOUT_MS=30000

# Telemetry
OTEL_SERVICE_NAME=proxx
OTEL_RESOURCE_ATTRIBUTES=service.name=proxx
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
