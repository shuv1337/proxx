# Big Ussy owned-fleet relay target
# Source this via scripts/deploy-target.sh big-ussy-owned-relay

DEPLOY_HOST=big.ussy.promethean.rest
DEPLOY_USER=error
DEPLOY_PATH=/home/error/devel/services/proxx
DEPLOY_COMPOSE_PROJECT_NAME=proxx-federation-runtime
DEPLOY_COMPOSE_FILES=docker-compose.federation-runtime.yml,deploy/docker-compose.big-ussy.host-caddy.yml
DEPLOY_HEALTH_SERVICE=federation-nginx
DEPLOY_RESTART_SERVICES=federation-proxx-a1,federation-proxx-a2,federation-proxx-b1,federation-proxx-b2,federation-nginx
DEPLOY_ENABLE_TLS=false

SOURCE_RUNTIME_DIR=${SOURCE_RUNTIME_DIR:-/home/err/devel/services/proxx}

PRE_DEPLOY_STOP_COMPOSE_DIR=${PRE_DEPLOY_STOP_COMPOSE_DIR:-/home/error/devel/services/cephalon-hive}
PRE_DEPLOY_STOP_SERVICES=${PRE_DEPLOY_STOP_SERVICES:-proxx}

BIG_USSY_PUBLIC_HOST_SUFFIX=${BIG_USSY_PUBLIC_HOST_SUFFIX:-big.ussy.promethean.rest}
BIG_USSY_DEFAULT_OWNER_SUBJECT=${BIG_USSY_DEFAULT_OWNER_SUBJECT:-did:web:big.ussy.promethean.rest}
BIG_USSY_ALLOWED_HOSTS=${BIG_USSY_ALLOWED_HOSTS:-federation.big.ussy.promethean.rest,brethren.big.ussy.promethean.rest,big.ussy.promethean.rest,a1.big.ussy.promethean.rest,a2.big.ussy.promethean.rest,b1.big.ussy.promethean.rest,b2.big.ussy.promethean.rest,group-a.big.ussy.promethean.rest,group-b.big.ussy.promethean.rest}
BIG_USSY_API_PORT=${BIG_USSY_API_PORT:-8789}
BIG_USSY_WEB_PORT=${BIG_USSY_WEB_PORT:-5174}
