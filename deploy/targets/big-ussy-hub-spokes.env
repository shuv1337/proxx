# Big Ussy hub-and-spokes target
# Canonical public core + private loopback-bound spokes matching local topology.

DEPLOY_HOST=big.ussy.promethean.rest
DEPLOY_USER=error
DEPLOY_PATH=/home/error/devel/services/proxx
DEPLOY_COMPOSE_PROJECT_NAME=proxx-big-ussy-hub-spokes
DEPLOY_COMPOSE_FILES=deploy/docker-compose.big-ussy.hub-spokes.yml
DEPLOY_HEALTH_SERVICE=proxx
DEPLOY_RESTART_SERVICES=proxx,proxx-federation-peer,proxx-blongs,cephalon-hive-proxx
DEPLOY_ENABLE_TLS=false

SOURCE_RUNTIME_DIR=${SOURCE_RUNTIME_DIR:-/home/err/devel/services/proxx}

PRE_DEPLOY_DOWN_COMPOSE_DIR=${PRE_DEPLOY_DOWN_COMPOSE_DIR:-/home/error/devel/services/proxx}
PRE_DEPLOY_DOWN_COMPOSE_PROJECT_NAME=${PRE_DEPLOY_DOWN_COMPOSE_PROJECT_NAME:-proxx-federation-runtime}
PRE_DEPLOY_DOWN_COMPOSE_FILES=${PRE_DEPLOY_DOWN_COMPOSE_FILES:-docker-compose.federation-runtime.yml,deploy/docker-compose.big-ussy.host-caddy.yml}
POST_DEPLOY_REMOTE_SCRIPT=${POST_DEPLOY_REMOTE_SCRIPT:-scripts/bootstrap-big-ussy-hub-spokes.sh}

BIG_USSY_CANONICAL_PUBLIC_HOST=federation.big.ussy.promethean.rest
BIG_USSY_PUBLIC_HOST_SUFFIX=big.ussy.promethean.rest
BIG_USSY_DEFAULT_OWNER_SUBJECT=did:web:big.ussy.promethean.rest
BIG_USSY_ALLOWED_HOSTS=127.0.0.1,localhost,federation.big.ussy.promethean.rest,brethren.big.ussy.promethean.rest
BIG_USSY_CORE_PEER_DID=did:web:federation.big.ussy.promethean.rest
BIG_USSY_FEDERATION_PEER_DID=did:web:big.ussy.promethean.rest:spokes:federation
BIG_USSY_BLONGS_PEER_DID=did:web:big.ussy.promethean.rest:spokes:blongs
BIG_USSY_CEPHALON_PEER_DID=did:web:big.ussy.promethean.rest:spokes:cephalon
FEDERATION_SELF_PUBLIC_BASE_URL=https://federation.big.ussy.promethean.rest
FEDERATION_PROXY_AUTH_TOKEN=big-ussy-federation-spoke-token
BLONGS_PROXY_AUTH_TOKEN=big-ussy-blongs-spoke-token
PROXX_PROXY_AUTH_TOKEN=big-ussy-cephalon-spoke-token

BIG_USSY_API_PORT=8789
BIG_USSY_WEB_PORT=5174

DEPLOY_KEYS_JSON_STRIP_OAUTH_BEARER_PROVIDER_IDS=openai
DEPLOY_ENV_PASSTHROUGH_KEYS="BIG_USSY_CANONICAL_PUBLIC_HOST BIG_USSY_PUBLIC_HOST_SUFFIX BIG_USSY_DEFAULT_OWNER_SUBJECT BIG_USSY_ALLOWED_HOSTS BIG_USSY_CORE_PEER_DID BIG_USSY_FEDERATION_PEER_DID BIG_USSY_BLONGS_PEER_DID BIG_USSY_CEPHALON_PEER_DID FEDERATION_SELF_PUBLIC_BASE_URL FEDERATION_PROXY_AUTH_TOKEN BLONGS_PROXY_AUTH_TOKEN PROXX_PROXY_AUTH_TOKEN"
